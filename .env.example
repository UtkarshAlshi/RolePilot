# Core runtime
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-32+char-secret"

# Database (managed Postgres in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_copilot"

# Demo auth (disable in production)
AUTH_DEMO_EMAIL="demo@example.com"
AUTH_DEMO_PASSWORD="demo-password"
AUTH_ALLOW_DEMO_LOGIN="true"

# Resume storage
# local: simple URL passthrough for development
# s3: set provider=s3 and point RESUME_STORAGE_BASE_URL to your signed-upload endpoint/domain
RESUME_STORAGE_PROVIDER="local"
RESUME_STORAGE_BUCKET="local-dev"
RESUME_STORAGE_BASE_URL="https://example.local/storage"
RESUME_UPLOAD_URL_TTL_SECONDS="900"
RESUME_STORAGE_SIGNING_SECRET="replace-with-storage-signing-secret"

# Optional error monitoring endpoint/DSN
ERROR_MONITOR_DSN="https://example.com/monitoring"

# Optional LLM integration (keeps deterministic fallbacks when unset)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
